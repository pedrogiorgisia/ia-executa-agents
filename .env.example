# ============================================
# ia-executa-agents — .env.example
# Copie este arquivo pra .env e preencha com valores reais.
# NUNCA commitar o .env.
# ============================================

# --- Anthropic Claude API ---
# Obtém em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modelo padrão dos agentes (Haiku mais barato, Sonnet mais caro mas melhor)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Google Gemini (imagens, free tier 500/dia) ---
# Obtém em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# --- Meta Instagram Graph API ---
# Criar app em https://developers.facebook.com após App Review
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Resend (email nurture + news diário, free tier 3k/mês) ---
# Obtém em: https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
# Email destinatário do news-curator diário (você)
NEWS_EMAIL_DESTINATARIO=pedro.giorgis@gmail.com

# --- GitHub (não usado pelo news-curator — histórico cloud vem do Gmail MCP) ---
# Mantido aqui caso outros agentes futuros precisem.
# GITHUB_PAT=
# GITHUB_REPO=pedrogiorgisia/ia-executa-agents

# --- Telegram bot (notificações e gates humanos) ---
# Criar bot via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_PEDRO=

# --- Brave Search (tendências, free tier 2k/mês) ---
# Obtém em: https://brave.com/search/api
BRAVE_SEARCH_API_KEY=

# --- Caminhos locais ---
# Path absoluto pra pasta de negócio (somente-leitura)
NEGOCIO_PATH=G:\Meu Drive\20-empresas e projetos pessoais\projetos-paralelos\01-ativas\01-empresa-ia-pedro\01-negocio

# Path do SQLite
DB_PATH=./agents.db

# --- Guardrails ---
# Budget máximo diário em USD (pausa tudo se exceder)
MAX_DAILY_BUDGET_USD=2.00

# Modo dry-run global (true = nada executa efeitos externos)
DRY_RUN=true
